# Shared by app + ingestion (both run as the same identity against the same services) ---
APIM_BASE_URL=https://<gateway>.azure-api.net/ai/v1
APIM_KEY=<apim-subscription-key from kv-app>       
SEARCH_ENDPOINT=https://<search-service>.search.windows.net
SEARCH_INDEX=ragchat-docs
PG_HOST=<server>.postgres.database.azure.com
PG_DB=ragchat
PG_USER=<uami-name>                                
EMBED_MODEL=text-embedding-3-large
# EMBED_BATCH_SIZE=64                               # chunks per embeddings request

# app only
CHAT_MODELS=gpt-5-mini,gpt-4.1-nano                # picker options (CSV of Foundry deployments); first is the default. Provisioned by azd from main.bicep's chatModels; one APIM route serves them all (routed by the body's `model`)
ENABLE_STREAMING=true                              # stream the answer token-by-token over SSE (needs a streaming-capable APIM SKU; see infra)

# ingestion only 
BLOB_ACCOUNT=<storage-account>                      
BLOB_CONTAINER=documents                            
QUEUE_NAME=ingest-events                            
CHUNK_MAX_TOKENS=1024                               

# optional
# SEARCH_API_VERSION=2024-07-01                     # AI Search REST API version
# SEARCH_BATCH_SIZE=500                             # docs per index request
# APPLICATIONINSIGHTS_CONNECTION_STRING=